{
  "manifest_version": 3,
  "name": "CodeHound",
  "version": "1.0.0",
  "description": "Sniffs out verification codes from Gmail and copies them to your clipboard.",
  "permissions": ["identity", "clipboardWrite", "storage"],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*"
  ],
  "oauth2": {
    "client_id": "924033159870-g4guhjc65ps1i7vbqcgteai666hv04pb.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/gmail.readonly"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
